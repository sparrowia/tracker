# Copy to agent-runner/.env and fill in. Supabase + Slack values are the SAME
# ones already in the tracker's root .env.local — just copy them here.

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SLACK_BOT_TOKEN=

# The repo the agents work in (the platform monorepo by default).
REPO_PATH=/Volumes/Avalon/Working/edcetera-platform

# How often each runner checks for its turn.
POLL_SECONDS=15
MAX_REVIEW_ROUNDS=2

# AGENT and AGENT_CMD are set by the start scripts (start-claude.sh / start-gpt.sh),
# so you don't need them here.
